---
import Link from "@components/navigation/Link.astro";
import OpeningHours from "@components/helpers/OpeningHours.astro";

interface Props {
  settings: any;
  lang: string;
}
const { settings, lang } = Astro.props;

const {
  company_name,
  address,
  opening_hours,
  footer_text,
  footer_menu_1,
  footer_menu_2,
  email,
  phone,
  phone_label,
  whatsapp,
  links,
  footer_menu_1_label,
  footer_menu_2_label,
  footer_3_label,
  payment_methods,
} = settings;

const paymentBadges = payment_methods
  ? payment_methods.split(",").map((m: string) => m.trim()).filter(Boolean)
  : [];

const socialLinkClass =
  "flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-lg text-gray-300 transition-colors duration-200 hover:bg-white/10 hover:text-white active:bg-white/15";
const navLinkClass =
  "link flex min-h-9 items-center gap-1 text-sm text-gray-400 transition-colors duration-200 hover:text-white active:text-white";
---

<!-- Footer container -->
<footer class="relative bg-gray-900 text-white">
  <div class="absolute inset-x-0 top-0 h-1 bg-primary" aria-hidden="true"></div>

  <!-- Main grid section -->
  <div class="px-6 sm:px-8 lg:px-12 pt-16 pb-10">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 md:grid-cols-3 md:gap-12">

      <!-- Col 1: Brand + contact + social -->
      <div class="flex flex-col gap-5">
        <img
          src="/screenshots/logo-cora-blanco.webp"
          alt={company_name}
          width="1063"
          height="585"
          loading="lazy"
          decoding="async"
          class="h-16 w-auto object-contain"
        />
        <div class="text-sm text-gray-400 leading-relaxed" set:html={footer_text} />

        {paymentBadges.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {paymentBadges.map((method: string) => (
              <span class="rounded-full border border-gray-700 bg-gray-800 px-3 py-1 text-xs font-medium text-gray-300">
                {method}
              </span>
            ))}
          </div>
        )}

        <div class="flex flex-col gap-2.5 text-sm text-gray-400">
          {address && (
            <p class="flex items-center gap-2">
              <svg class="h-4 w-4 shrink-0 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11Z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
              {address}
            </p>
          )}
          {email && (
            <a href={`mailto:${email}`} class="flex items-center gap-2 transition-colors duration-200 hover:text-white active:text-white">
              <svg class="h-4 w-4 shrink-0 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m4 7 8 6 8-6" />
              </svg>
              {email}
            </a>
          )}
          {phone && (
            <a href={`tel:${phone}`} class="flex items-center gap-2 transition-colors duration-200 hover:text-white active:text-white">
              <svg class="h-4 w-4 shrink-0 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
              </svg>
              {phone_label || phone}
            </a>
          )}
        </div>

        <!-- Social icons -->
        <ul class="mt-1 flex gap-2">
          {
            links &&
              links.length > 0 &&
              links.map((link: any) => (
                <li>
                  <Link blok={link} hideLabel className={socialLinkClass} />
                </li>
              ))
          }
          {
            whatsapp && (
              <li>
                <Link
                  blok={{
                    icon: "whatsapp",
                    href: {
                      linktype: "url",
                      url: `https://wa.me/${whatsapp}`,
                    },
                    label: "WhatsApp",
                  }}
                  hideLabel
                  className={socialLinkClass}
                />
              </li>
            )
          }
        </ul>
      </div>

      <!-- Col 2: Navigation menus -->
      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          {footer_menu_1_label && (
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary">
              {footer_menu_1_label}
            </h3>
          )}
          <ul class="flex flex-col">
            {
              footer_menu_1 &&
                footer_menu_1.length > 0 &&
                footer_menu_1.map((link: any) => (
                  <li>
                    <Link blok={link} className={navLinkClass} />
                  </li>
                ))
            }
          </ul>
        </div>

        <div class="flex flex-col gap-3">
          {footer_menu_2_label && (
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary">
              {footer_menu_2_label}
            </h3>
          )}
          <ul class="flex flex-col">
            {
              footer_menu_2 &&
                footer_menu_2.length > 0 &&
                footer_menu_2.map((link: any) => (
                  <li>
                    <Link blok={link} className={navLinkClass} />
                  </li>
                ))
            }
          </ul>
        </div>
      </div>

      <!-- Col 3: Opening hours -->
      <div class="flex flex-col gap-3">
        {footer_3_label && (
          <h3 class="text-xs font-bold uppercase tracking-widest text-primary">
            {footer_3_label}
          </h3>
        )}
        <div class="rounded-xl border border-gray-800 bg-white/5 p-4 text-sm text-gray-400">
          {opening_hours && <OpeningHours {opening_hours} {lang} />}
        </div>
      </div>

    </div>
  </div>

  <!-- Divider -->
  <div class="border-t border-gray-800 mx-6 sm:mx-8 lg:mx-12"></div>

  <!-- Copyright section -->
  <div class="px-6 sm:px-8 lg:px-12 py-6 text-center text-xs text-gray-500">
    <span>© {new Date().getFullYear()} {company_name}</span>
    <span class="mx-1.5 text-gray-700">·</span>
    <span>Cocina Peruana en Lobitos, Perú</span>
  </div>

</footer>
