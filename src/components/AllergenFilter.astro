---
// src/components/AllergenFilter.astro
---

<div
  class="allergen-filter-container w-full bg-white/95 dark:bg-black/95 backdrop-blur-md sticky z-40 border-b border-gray-200 dark:border-gray-800 transition-colors"
  style="top: var(--sticky-header-h, 69px);"
>
  <div class="px-4 sm:px-6 lg:px-8 py-2">
    <!-- Chips: una sola línea con scroll lateral (swipe) en todos los tamaños -->
    <div class="relative">
      <div
        id="allergen-container"
        class="flex flex-nowrap items-center gap-2 overflow-x-auto"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        <button data-exclude="todos" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-black text-white border-black dark:bg-white dark:text-black dark:border-white">
          Todos
        </button>
        <button data-exclude="mariscos" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Mariscos
        </button>
        <button data-exclude="pescado" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Pescado
        </button>
        <button data-exclude="cítricos" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Cítricos
        </button>
        <button data-exclude="gluten" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Gluten
        </button>
        <button data-exclude="huevo" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Huevo
        </button>
        <button data-exclude="soya" type="button" class="allergen-btn flex min-h-11 flex-shrink-0 items-center whitespace-nowrap rounded-full border px-4 text-xs sm:text-sm font-medium transition-colors duration-150 active:scale-95 bg-white text-gray-700 border-gray-300 active:bg-gray-100 dark:bg-black dark:text-gray-300 dark:border-gray-700 dark:active:bg-gray-800">
          Sin Soya
        </button>
      </div>
      <button
        type="button"
        data-fade="left"
        aria-label="Ver filtros anteriores"
        class="absolute inset-y-0 left-0 flex w-10 items-center justify-start bg-gradient-to-r from-white/95 dark:from-black/95 to-transparent pl-0.5 opacity-0 transition-opacity duration-200 active:from-white dark:active:from-black"
        style="pointer-events: none;"
      >
        <svg class="h-5 w-5 animate-pulse-x-reverse text-gray-500 dark:text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m15 6-6 6 6 6" />
        </svg>
      </button>
      <button
        type="button"
        data-fade="right"
        aria-label="Ver más filtros"
        class="absolute inset-y-0 right-0 flex w-10 items-center justify-end bg-gradient-to-l from-white/95 dark:from-black/95 to-transparent pr-0.5 opacity-0 transition-opacity duration-200 active:from-white dark:active:from-black"
        style="pointer-events: none;"
      >
        <svg class="h-5 w-5 animate-pulse-x text-gray-500 dark:text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  import { initScrollFade } from "@/lib/scrollFade";
  import { initStickyOffsets } from "@/lib/stickyOffsets";

  function initAllergenFilters() {
    const buttons = document.querySelectorAll<HTMLElement>('.allergen-btn');
    const cards = document.querySelectorAll<HTMLElement>('.dish-card');

    if (cards.length === 0) {
      console.error("[Filtros] ERROR: No se encontraron elementos con la clase '.dish-card'.");
      return;
    }

    buttons.forEach(button => {
      const newBtn = button.cloneNode(true) as HTMLElement;
      if (button.parentNode) {
        button.parentNode.replaceChild(newBtn, button);
      }

      newBtn.addEventListener('click', () => {
        // Estado visual activo
        document.querySelectorAll<HTMLElement>('.allergen-btn').forEach(b => {
          b.classList.remove('bg-black', 'text-white', 'border-black');
          b.classList.add('bg-white', 'text-black');
        });
        newBtn.classList.remove('bg-white', 'text-black');
        newBtn.classList.add('bg-black', 'text-white', 'border-black');

        // Filtrado
        const excludeWord = newBtn.getAttribute('data-exclude');

        cards.forEach(card => {
          if (excludeWord === 'todos') {
            card.style.display = '';
            return;
          }
          const allergensRaw = card.getAttribute('data-allergens');
          try {
            const allergens = allergensRaw ? JSON.parse(allergensRaw) : [];
            card.style.display = allergens.includes(excludeWord) ? 'none' : '';
          } catch (e) {
            console.error("[Filtros] Error parseando JSON:", allergensRaw);
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initAllergenFilters);
  document.addEventListener('astro:page-load', initAllergenFilters);

  function initAllergenScrollFade() {
    initScrollFade('allergen-container');
  }
  document.addEventListener('DOMContentLoaded', initAllergenScrollFade);
  document.addEventListener('astro:page-load', initAllergenScrollFade);

  document.addEventListener('DOMContentLoaded', initStickyOffsets);
  document.addEventListener('astro:page-load', initStickyOffsets);
</script>
