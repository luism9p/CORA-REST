---
// ActionButtons.astro — FABs flotantes: QR de pagos + Feedback WhatsApp
interface Props {
  whatsappNumber?: string;
  whatsappMessage?: string;
}

const {
  whatsappNumber = "51000000000",
  whatsappMessage = "Hola, tengo un comentario sobre el restaurante",
} = Astro.props;

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<!-- Floating Action Buttons -->
<div
  class="fixed bottom-6 right-4 z-50 flex flex-col items-end gap-3"
  aria-label="Acciones rápidas"
>
  <!-- Tooltip labels -->

  <!-- FAB 1: Pagos QR -->
  <div class="group flex items-center gap-2">
    <span
      class="pointer-events-none translate-x-2 rounded-lg bg-gray-900/90 px-3 py-1.5 text-xs font-semibold text-white opacity-0 shadow-lg backdrop-blur-sm transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100"
    >
      Pagar con QR
    </span>
    <button
      id="btn-open-qr"
      aria-label="Ver códigos QR de pago"
      class="flex h-13 w-13 items-center justify-center rounded-full bg-gray-900 text-white shadow-xl ring-2 ring-white/20 transition-all duration-200 hover:scale-110 hover:bg-gray-700 active:scale-95"
    >
      <!-- QR icon -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6">
        <path d="M3 3h7v7H3V3zm1 1v5h5V4H4zm1 1h3v3H5V5zM3 14h7v7H3v-7zm1 1v5h5v-5H4zm1 1h3v3H5v-3zM14 3h7v7h-7V3zm1 1v5h5V4h-5zm1 1h3v3h-3V5zM14 14h2v2h-2v-2zm2 2h2v2h-2v-2zm2-2h2v2h-2v-2zm0 4h2v2h-2v-2zm-4 0h2v2h-2v-2zm2-2h2v2h-2v-2z"/>
      </svg>
    </button>
  </div>

  <!-- FAB 2: Feedback WhatsApp -->
  <div class="group flex items-center gap-2">
    <span
      class="pointer-events-none translate-x-2 rounded-lg bg-[#25D366]/90 px-3 py-1.5 text-xs font-semibold text-white opacity-0 shadow-lg backdrop-blur-sm transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100"
    >
      Dejar feedback
    </span>
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Dejar feedback por WhatsApp"
      class="flex h-13 w-13 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl ring-2 ring-white/20 transition-all duration-200 hover:scale-110 hover:bg-[#1db954] active:scale-95"
    >
      <!-- WhatsApp icon -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </div>
</div>
