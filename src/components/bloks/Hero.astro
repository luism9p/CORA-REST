---
/* import { Icon } from "astro-icon/components"; */
import VideoInline from "@components/media/VideoInline.vue";
import Link from "@components/navigation/Link.astro";

interface Props {
  blok: any;
}

const { blok } = Astro.props;
const {
  links,
  title,
  content,
  video,
  thumbnail,
  surface,
  bg_opacity,
  accent_color,
} = blok;

/* content is now a pre-rendered HTML string from JSON */
const text = content || "";
---

<div
  style={`--accent-color: rgb(var(${accent_color}));`}
  class={`${surface || ""} hero relative grid grid-cols-1 items-center parallax-wrap overflow-hidden  `}
>
  {
    thumbnail && (
      <div class={`parallax absolute inset-0 ${bg_opacity || ""}`}>
        {video?.filename && (
          <VideoInline url={video.filename} client:visible className="">
            {thumbnail?.filename && (
              <picture class="contents">
                <source srcset="/screenshots/fondov2.avif" type="image/avif" />
                <source srcset="/screenshots/fondov2.webp" type="image/webp" />
                <img
                  src="/screenshots/fondov2.webp"
                  alt="Fondo Cora"
                  width="1672"
                  height="941"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover -z-10"
                />
              </picture>
            )}
          </VideoInline>
        )}
        {!video?.filename && (
          <picture class="contents">
            <source srcset="/screenshots/fondov2.avif" type="image/avif" />
            <source srcset="/screenshots/fondov2.webp" type="image/webp" />
            <img
              src="/screenshots/fondov2.webp"
              alt="Fondo Cora"
              width="1672"
              height="941"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover -z-10 parallax"
            />
          </picture>
        )}
      </div>
    )
  }

  {/* Foto de la cocinera con el ceviche: solo en móvil, para darle impacto visual al hero */}
  <div class="hero-splash pointer-events-none absolute -bottom-2 -right-2 z-20 w-[58%] max-w-[300px] md:hidden">
    <picture>
      <source srcset="/screenshots/hero-chef-splash.avif" type="image/avif" />
      <source srcset="/screenshots/hero-chef-splash.webp" type="image/webp" />
      <img
        src="/screenshots/hero-chef-splash.webp"
        alt="Nuestra cocinera preparando ceviche fresco en CORA"
        width="800"
        height="820"
        loading="eager"
        decoding="async"
        class="hero-splash-pop h-auto w-full drop-shadow-2xl"
      />
    </picture>
  </div>

  <div class="content-grid relative h-fit">
    <div class="grid max-w-3xl grid-cols-1 gap-3 text-balance pt-20 pb-20 md:pt-28 md:pb-24">
      <h1 class="text-5xl md:text-6xl" set:html={title} />
      {content && <div class="no-lead text-xl" set:html={text} />}
      {
        links && links.length > 0 && (
          <div class="mt-4 flex flex-col sm:flex-row flex-wrap items-start gap-3 relative z-10">
            {/* CTA principal desde CMS */}
            {links.map((link: any) => (
              <Link blok={link} />
            ))}

            {/* Botón QR Pagos */}
            <button
              id="btn-open-qr"
              class="inline-flex items-center gap-2 rounded-full bg-white/90 px-5 py-2.5 text-sm font-bold text-red-600 shadow-lg backdrop-blur-sm transition-all duration-200 hover:bg-white hover:shadow-xl active:scale-95"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="3" height="3"/>
                <rect x="18" y="18" width="3" height="3"/>
              </svg>
              Pagar con QR
            </button>

            {/* Botón Feedback: reseña en Google Maps */}
            <a
              id="btn-feedback"
              href="https://maps.app.goo.gl/dmrwGnFMgc9u3YTY6"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-white/90 px-5 py-2.5 text-sm font-bold text-red-600 shadow-lg backdrop-blur-sm transition-all duration-200 hover:bg-white hover:shadow-xl active:scale-95"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21Z"/>
              </svg>
              Dar Feedback
            </a>
          </div>
        )
      }
    </div>
  </div>
</div>

<style is:global>
  @screen md {
    .hero {
      min-height: max(100svh, 30rem);
    }
  }

  .hero {
    h1 {
      strong,
      b,
      bold {
        @apply underline;
        font-weight: inherit;
        color: var(--accent-color);
      }
    }
  }

  @keyframes hero-splash-float {
    0%, 100% { transform: rotate(-4deg) translateY(0); }
    50% { transform: rotate(-4deg) translateY(-8px); }
  }
  .hero-splash {
    animation: hero-splash-float 4.5s ease-in-out infinite;
  }

  @keyframes hero-splash-pop {
    0% { opacity: 0; transform: scale(0.85) translateY(12px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  .hero-splash-pop {
    animation: hero-splash-pop 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-splash,
    .hero-splash-pop {
      animation: none;
    }
  }
</style>
