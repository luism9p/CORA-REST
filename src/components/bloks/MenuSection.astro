---
import MenuItemCard from "@components/cards/MenuItemCard.astro";

// 1. Tipado estricto para nuestra nueva estructura JSON
interface MenuItem {
  id: string;
  translations: Record<string, { name: string; description: string }>;
  prices: { label: string; amount: number }[];
  allergens: string[];
}

interface MenuCategory {
  category_id: string;
  category_translations: Record<string, string>;
  items: MenuItem[];
}

interface Props {
  id?: string;
  surface?: string;
  menu: MenuCategory[]; // Ahora menu espera directamente el array de categorías
}

const { id, surface, menu } = Astro.props;
---

<section
  class={`content-grid pt-4 pb-14 md:pt-10 ${surface || ""}`}
  id={id}
>
  {/* Renderizado de la navegación horizontal por categorías */}
  {
    menu && menu.length > 1 && (
      <div
        class="breakout sticky z-30 mb-2 w-full bg-white/80 dark:bg-black/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-900 px-4 sm:px-6 py-3"
        style="top: calc(var(--sticky-header-h, 69px) + var(--sticky-allergen-h, 69px));"
      >
        {/* Lista de chips de categorías: una sola línea con scroll lateral (swipe) */}
        <div class="relative">
          <ul
            id="category-container"
            class="flex flex-nowrap items-center gap-2 overflow-x-auto"
            style="scrollbar-width: none; -ms-overflow-style: none;"
          >
            {menu.map((cat) => (
              <li class="flex shrink-0">
                <a
                  class="flex min-h-11 items-center rounded-full bg-primary px-4 text-xs font-semibold text-white whitespace-nowrap transition-colors duration-150 active:opacity-80 md:text-sm i18n-element"
                  data-translations={JSON.stringify(cat.category_translations)}
                  href={`#${cat.category_id}`}
                >
                  {cat.category_translations.es}
                </a>
              </li>
            ))}
          </ul>
          <button
            type="button"
            data-fade="left"
            aria-label="Ver categorías anteriores"
            class="absolute inset-y-0 left-0 flex w-10 items-center justify-start bg-gradient-to-r from-white/90 dark:from-black/90 to-transparent pl-0.5 opacity-0 transition-opacity duration-200 active:from-white dark:active:from-black"
            style="pointer-events: none;"
          >
            <svg class="h-5 w-5 animate-pulse-x-reverse text-gray-500 dark:text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m15 6-6 6 6 6" />
            </svg>
          </button>
          <button
            type="button"
            data-fade="right"
            aria-label="Ver más categorías"
            class="absolute inset-y-0 right-0 flex w-10 items-center justify-end bg-gradient-to-l from-white/90 dark:from-black/90 to-transparent pr-0.5 opacity-0 transition-opacity duration-200 active:from-white dark:active:from-black"
            style="pointer-events: none;"
          >
            <svg class="h-5 w-5 animate-pulse-x text-gray-500 dark:text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" />
            </svg>
          </button>
        </div>
      </div>
    )
  }

  {/* Renderizado de las secciones y platos */}
  <div class="breakout grid gap-16 md:gap-24 px-4 sm:px-6 md:px-0">
    {
      menu.map((cat) => (
        <div class="grid scroll-mt-28 gap-6 md:gap-10" id={cat.category_id}>
          <div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black uppercase mb-2 tracking-tight text-red-600 i18n-element" data-translations={JSON.stringify(cat.category_translations)}>{cat.category_translations.es}</h2>
            <div class="h-0.5 w-16 bg-current opacity-30 mb-6 md:mb-10"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-16 md:gap-y-10">
            {cat.items.map((item) => (
              <MenuItemCard content={item} />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Ocultar scrollbar en móviles pero mantener la funcionalidad */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>

<script>
  import { initScrollFade } from "@/lib/scrollFade";

  function updateTranslations() {
    const lang = localStorage.getItem('preferredLanguage') || 'es';
    const elements = document.querySelectorAll('.i18n-element');
    
    elements.forEach(el => {
      try {
        const rawTranslations = el.getAttribute('data-translations');
        if (!rawTranslations) return;
        
        const translations = JSON.parse(rawTranslations);
        const key = el.getAttribute('data-key');
        
        let text = '';
        
        // Handle object with nested key (like { translations: { es: { name: '...' } } })
        if (key) {
          if (translations[lang] && translations[lang][key]) {
            text = translations[lang][key];
          } else if (translations['es'] && translations['es'][key]) {
            text = translations['es'][key]; // fallback to Spanish
          }
        } 
        // Handle direct string map (like { category_translations: { es: '...' } })
        else {
          if (typeof translations[lang] === 'string') {
            text = translations[lang];
          } else if (typeof translations['es'] === 'string') {
            text = translations['es']; // fallback to Spanish
          }
        }
        
        if (text) {
          el.textContent = text;
        }
      } catch (err) {
        console.error('Error updating translation for element', el, err);
      }
    });
  }

  // Listen to the custom event
  window.addEventListener('languageChanged', () => {
    updateTranslations();
  });

  // Run on load to apply any previously saved language
  document.addEventListener('astro:page-load', updateTranslations);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateTranslations);
  } else {
    updateTranslations();
  }

  function initCategoryScrollFade() {
    initScrollFade('category-container');
  }
  document.addEventListener('astro:page-load', initCategoryScrollFade);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoryScrollFade);
  } else {
    initCategoryScrollFade();
  }
</script>