---
import MenuItemCard from "@components/cards/MenuItemCard.astro";

// 1. Tipado estricto para nuestra nueva estructura JSON
interface MenuItem {
  id: string;
  translations: Record<string, { name: string; description: string }>;
  prices: { label: string; amount: number }[];
  allergens: string[];
}

interface MenuCategory {
  category_id: string;
  category_translations: Record<string, string>;
  items: MenuItem[];
}

interface Props {
  id?: string;
  surface?: string;
  menu: MenuCategory[]; // Ahora menu espera directamente el array de categorías
}

const { id, surface, menu } = Astro.props;
---

<section
  class={`content-grid pt-4 pb-14 md:pt-10 ${surface || ""}`}
  id={id}
>
  {/* Renderizado de la navegación horizontal por categorías */}
  {
    menu && menu.length > 1 && (
      <div class={`breakout sticky top-[52px] z-30 mb-2 w-full bg-white/80 dark:bg-black/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-900 px-4 sm:px-6 py-3`}>
        {/* Lista de chips de categorías */}
        <ul
          id="category-container"
          class="flex flex-wrap gap-2 overflow-hidden transition-[max-height] duration-300 ease-in-out max-h-[42px] md:flex-nowrap md:overflow-x-auto md:max-h-none"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {menu.map((cat) => (
            <li class="flex shrink-0">
              <a
                class="block px-4 py-2 bg-primary text-primary-fg text-xs md:text-sm font-semibold rounded-full whitespace-nowrap transition-colors hover:opacity-80 i18n-element"
                data-translations={JSON.stringify(cat.category_translations)}
                href={`#${cat.category_id}`}
              >
                {cat.category_translations.es}
              </a>
            </li>
          ))}
        </ul>

        {/* Botón toggle — solo móvil */}
        <button
          id="toggle-categories"
          class="md:hidden mt-2 mb-1 flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors bg-transparent border-none outline-none"
          aria-expanded="false"
        >
          <span id="toggle-categories-label">Ver más</span>
          <svg
            id="toggle-categories-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5 transition-transform duration-300"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    )
  }

  {/* Renderizado de las secciones y platos */}
  <div class="breakout grid gap-16 md:gap-24">
    {
      menu.map((cat) => (
        <div class="grid scroll-mt-28 gap-6 md:gap-10" id={cat.category_id}>
          <div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black uppercase mb-2 tracking-tight i18n-element" data-translations={JSON.stringify(cat.category_translations)}>{cat.category_translations.es}</h2>
            <div class="h-0.5 w-16 bg-current opacity-30 mb-6 md:mb-10"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-16 md:gap-y-10">
            {cat.items.map((item) => (
              <MenuItemCard content={item} />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Ocultar scrollbar en móviles pero mantener la funcionalidad */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>

<script>
  function updateTranslations() {
    const lang = localStorage.getItem('preferredLanguage') || 'es';
    const elements = document.querySelectorAll('.i18n-element');
    
    elements.forEach(el => {
      try {
        const rawTranslations = el.getAttribute('data-translations');
        if (!rawTranslations) return;
        
        const translations = JSON.parse(rawTranslations);
        const key = el.getAttribute('data-key');
        
        let text = '';
        
        // Handle object with nested key (like { translations: { es: { name: '...' } } })
        if (key) {
          if (translations[lang] && translations[lang][key]) {
            text = translations[lang][key];
          } else if (translations['es'] && translations['es'][key]) {
            text = translations['es'][key]; // fallback to Spanish
          }
        } 
        // Handle direct string map (like { category_translations: { es: '...' } })
        else {
          if (typeof translations[lang] === 'string') {
            text = translations[lang];
          } else if (typeof translations['es'] === 'string') {
            text = translations['es']; // fallback to Spanish
          }
        }
        
        if (text) {
          el.textContent = text;
        }
      } catch (err) {
        console.error('Error updating translation for element', el, err);
      }
    });
  }

  // Listen to the custom event
  window.addEventListener('languageChanged', () => {
    updateTranslations();
  });

  // Run on load to apply any previously saved language
  document.addEventListener('astro:page-load', updateTranslations);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateTranslations);
  } else {
    updateTranslations();
  }

  // --- Toggle Ver más / Ver menos para categorías ---
  function initCategoryToggle() {
    const toggleBtn = document.getElementById('toggle-categories');
    const container = document.getElementById('category-container');
    if (!toggleBtn || !container) return;

    const newToggleBtn = toggleBtn.cloneNode(true) as HTMLElement;
    toggleBtn.parentNode?.replaceChild(newToggleBtn, toggleBtn);

    let isExpanded = false;

    newToggleBtn.addEventListener('click', () => {
      isExpanded = !isExpanded;
      const label = newToggleBtn.querySelector<HTMLElement>('#toggle-categories-label');
      const icon = newToggleBtn.querySelector<HTMLElement>('#toggle-categories-icon');

      if (isExpanded) {
        container.style.maxHeight = container.scrollHeight + 'px';
        if (label) label.textContent = 'Ver menos';
        if (icon) icon.style.transform = 'rotate(180deg)';
        newToggleBtn.setAttribute('aria-expanded', 'true');
      } else {
        container.style.maxHeight = '42px';
        if (label) label.textContent = 'Ver más';
        if (icon) icon.style.transform = 'rotate(0deg)';
        newToggleBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initCategoryToggle);
  document.addEventListener('astro:page-load', initCategoryToggle);
</script>