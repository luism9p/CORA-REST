---
import PostClasicCard from "@components/cards/PostClasicCard.astro";

interface Props {
  blok: any;
}

const { blok } = Astro.props;
const { content, title, surface, accent_surface } = blok;

/* Stories are now passed directly via the blok prop from JSON */
const stories = blok.stories || [];
---

<section class={`py-14 md:py-20 ${surface || ""}`}>
  <div class="content-grid gap-y-8">
    <div class="breakout">
      <h2 class="text-4xl">
        {title}
      </h2>
      <div class="richtext" set:html={content || ""} />
    </div>
    {
      stories && stories.length > 0 && (
        <div class={`breakout flex flex-wrap gap-4 md:gap-8`}>
          {stories.map((story: any) => (
            <PostClasicCard
              {...story.content}
              full_slug={story.full_slug}
              accent={accent_surface}
            />
          ))}
        </div>
      )
    }
  </div>
</section>
